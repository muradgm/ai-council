  "ownerAgents": [
    "technical-writer",
    "product-manager"
  ],
  "skills": [
    "documentation",
    "product-management"
  ],
  "tags": [
    "documentation",
    "technical-writing",
    "onboarding"
  ],
  "keywords": [
    "docs",
    "documentation",
    "readme",
    "guide",
    "manual",
    "spec"
  ],
  "inputs": [
    "user_request",
    "project_context",
    "constraints",
    "existing_evidence",
    "candidate_options",
    "relevant_agents",
    "relevant_skills"
  ],
  "outputs": [
    "decision_summary",
    "recommended_option",
    "rationale",
    "tradeoffs",

    "qa-engineer",
    "product-manager",
    "devops-engineer"
  ],
  "skills": [
    "devops",
    "documentation",
    "product-management"
  ],
  "tags": [
    "release",
    "qa",
    "launch",
    "readiness"
  ],
  "keywords": [
    "release",
    "ship",
    "launch",
    "deploy",
    "production",
    "readiness",
    "checklist"
  ],
  "inputs": [
    "user_request",
    "project_context",
    "constraints",
    "existing_evidence",
    "candidate_options",
    "relevant_agents",
    "relevant_skills"
  ],
  "outputs": [
    "decision_summary",
    "recommended_option",
    "rationale",
    "tradeoffs",

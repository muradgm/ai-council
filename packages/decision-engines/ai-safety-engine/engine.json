{
  "name": "ai-safety-engine",
  "title": "AI Safety Engine",
  "version": "1.0.0",
  "entrypoint": "ENGINE.md",
  "category": "ai",
  "decisionType": "AI safety decision",
  "purpose": "Evaluate AI workflows for harmful misuse, overclaiming, unsafe automation, privacy leakage, and high-stakes boundaries.",
  "ownerAgents": [
    "chief-ai-officer",
    "risk-manager"
  ],
  "skills": [
    "risk-management"
  ],
  "tags": [
    "ai-safety",
    "risk",
    "guardrails",
    "policy"
  ],
  "keywords": [
    "ai safety",
    "guardrail",
    "unsafe",
    "risk",
    "policy",
    "automation",
    "high stakes"
  ],
  "inputs": [
    "user_request",
    "project_context",
    "constraints",
    "existing_evidence",
    "candidate_options",
    "relevant_agents",
    "relevant_skills"
  ],
  "outputs": [
    "decision_summary",
    "recommended_option",
    "rationale",
    "tradeoffs",
    "risk_register",
    "confidence_level",
    "next_actions",
    "what_would_change_the_decision"
  ],
  "rubricCriteria": [
    "harm potential",
    "user stakes",
    "autonomy level",
    "data sensitivity",
    "misuse risk",
    "human review need",
    "guardrail clarity"
  ],
  "guardrails": [
    "Do not overstate confidence. Use evidence, assumptions, and escalation when stakes are material.",
    "State assumptions explicitly.",
    "Separate facts, inference, and opinion.",
    "Prefer reversible decisions when evidence is weak."
  ]
}

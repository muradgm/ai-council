{
  "name": "security-review-engine",
  "title": "Security Review Engine",
  "version": "1.0.0",
  "entrypoint": "ENGINE.md",
  "category": "engineering",
  "decisionType": "security risk decision",
  "purpose": "Identify security risks, abuse cases, unsafe defaults, data exposure, and mitigation priorities.",
  "ownerAgents": [
    "cto",
    "principal-software-architect"
  ],
  "skills": [
    "api-design"
  ],
  "tags": [
    "security",
    "threat-model",
    "privacy",
    "risk"
  ],
  "keywords": [
    "security",
    "vulnerability",
    "auth",
    "permissions",
    "secret",
    "token",
    "privacy",
    "attack"
  ],
  "inputs": [
    "user_request",
    "project_context",
    "constraints",
    "existing_evidence",
    "candidate_options",
    "relevant_agents",
    "relevant_skills"
  ],
  "outputs": [
    "decision_summary",
    "recommended_option",
    "rationale",
    "tradeoffs",
    "risk_register",
    "confidence_level",
    "next_actions",
    "what_would_change_the_decision"
  ],
  "rubricCriteria": [
    "asset sensitivity",
    "attack surface",
    "exploitability",
    "impact",
    "mitigation clarity",
    "logging",
    "least privilege"
  ],
  "guardrails": [
    "Do not overstate confidence. Use evidence, assumptions, and escalation when stakes are material.",
    "State assumptions explicitly.",
    "Separate facts, inference, and opinion.",
    "Prefer reversible decisions when evidence is weak."
  ]
}

{
  "name": "release-readiness",
  "title": "Release Readiness Workflow",
  "version": "1.0.0",
  "entrypoint": "WORKFLOW.md",
  "category": "delivery",
  "description": "Check whether a feature, app, or system is safe to release against quality, security, docs, and rollback criteria.",
  "triggers": [
    "release",
    "deploy",
    "launch",
    "go live",
    "ship"
  ],
  "agents": [
    "project-manager",
    "qa-engineer",
    "devops-engineer",
    "cybersecurity-engineer"
  ],
  "skills": [
    "testing",
    "devops",
    "security",
    "documentation",
    "operations"
  ],
  "decisionEngines": [
    "release-readiness-engine",
    "security-review-engine",
    "testing-strategy-engine",
    "devops-engine"
  ],
  "phases": [
    "01-intake",
    "02-routing",
    "03-analysis",
    "04-plan",
    "05-execute",
    "06-review"
  ],
  "outputs": [
    "Release checklist",
    "Go/no-go decision",
    "Rollback plan",
    "Known risks"
  ],
  "qualityGates": [
    "scope-is-clear",
    "references-exist",
    "risks-are-visible",
    "validation-is-defined",
    "documentation-updated"
  ],
  "safety": "Follow project safety, privacy, security, and user-confirmation boundaries."
}
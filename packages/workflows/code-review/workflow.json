{
  "name": "code-review",
  "title": "Code Review Workflow",
  "version": "1.0.0",
  "entrypoint": "WORKFLOW.md",
  "category": "engineering",
  "description": "Review code for correctness, maintainability, architecture fit, security, tests, and developer ergonomics.",
  "triggers": [
    "review code",
    "pull request",
    "PR review",
    "code quality",
    "bug risk"
  ],
  "agents": [
    "code-reviewer",
    "principal-software-architect",
    "cybersecurity-engineer",
    "qa-engineer"
  ],
  "skills": [
    "code-review",
    "software-architecture",
    "security",
    "testing",
    "performance"
  ],
  "decisionEngines": [
    "code-review-engine",
    "security-review-engine",
    "performance-engine",
    "testing-strategy-engine"
  ],
  "phases": [
    "01-intake",
    "02-routing",
    "03-analysis",
    "04-plan",
    "05-execute",
    "06-review"
  ],
  "outputs": [
    "Code review report",
    "Severity-ranked findings",
    "Suggested fixes",
    "Test gaps"
  ],
  "qualityGates": [
    "scope-is-clear",
    "references-exist",
    "risks-are-visible",
    "validation-is-defined",
    "documentation-updated"
  ],
  "safety": "Follow project safety, privacy, security, and user-confirmation boundaries."
}
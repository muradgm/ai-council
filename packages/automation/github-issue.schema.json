{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub Issue Draft",
  "type": "object",
  "required": [
    "id",
    "project",
    "title",
    "body",
    "labels",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    }
  },
  "additionalProperties": true
}

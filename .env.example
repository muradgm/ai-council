AI_COUNCIL_DEFAULT_PROVIDER=local
AI_COUNCIL_LOCAL_PROVIDER=ollama
AI_COUNCIL_PRIVACY_MODE=local-first

# Local development services. Copy this file to .env and choose private values.
POSTGRES_USER=ai_council
POSTGRES_PASSWORD=
POSTGRES_DB=ai_council
MINIO_ROOT_USER=ai_council
MINIO_ROOT_PASSWORD=

# Optional model/provider credentials. Leave blank unless you intend to use them.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Optional model overrides. Leave blank to use repo defaults.
OPENAI_MODEL=
GEMINI_FREE_MODEL=
GEMINI_PRO_MODEL=
DEEPSEEK_MODEL=
XAI_MODEL=
MISTRAL_MODEL=

# Optional endpoint overrides for compatible gateways/proxies.
OPENAI_CHAT_COMPLETIONS_URL=
DEEPSEEK_CHAT_COMPLETIONS_URL=
XAI_CHAT_COMPLETIONS_URL=
MISTRAL_CHAT_COMPLETIONS_URL=
GEMINI_API_BASE_URL=
